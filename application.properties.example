# Unified application properties
# Shared Micronaut settings
# micronaut.application.name is set via system properties in build.gradle

# Shared logging settings
client.rootpath=\path\to\remoteclient\client
client.resourcespath=resources
client.logpath=logs
client.dataininame=Data.ini
client.usepathmappings=true
client.autoextract=true
client.enablesearch=true
client.cache.max-files=1000
client.cache.max-memory-mb=1024
client.cache.warmup.enabled=true
client.cache.warmup.limit=500

# Proxy settings (used by both client and wsproxy)
wsproxy.enabled=true
wsproxy.allowed-targets=127.0.0.1:6900,127.0.0.1:6121,127.0.0.1:5121

# Server ports
client.server.port=3338
wsproxy.server.port=5999

# Healthcheck settings (requires micronaut-management)
endpoints.health.enabled=true
endpoints.health.details-visible=anonymous

# Startup tasks
client.tasks.validate-grfs=true
client.tasks.mapping-output=path-mapping.json

# Debugging settings
# Sets Logback root level via ${LOG_LEVEL}
LOG_LEVEL=DEBUG
# Sets Micronaut managed loggers
logger.levels.root=DEBUG
logger.levels.turoran=DEBUG
